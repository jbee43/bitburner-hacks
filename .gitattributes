# Force LF line endings everywhere — matches .editorconfig (end_of_line = lf).
# Prevents CRLF issues when editing on Windows.
* text=auto eol=lf

# Windows batch scripts must keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Common binaries.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
